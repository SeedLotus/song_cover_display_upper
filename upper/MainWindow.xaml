<Window x:Class="upper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:upper"
        mc:Ignorable="d"
        Title="唱片机控制器 - @realTiX" 
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        Height="370" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="系统媒体播放状态" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <!-- 媒体信息显示区域 -->
        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 专辑封面 -->
                <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" 
                    Width="240" Height="240" Margin="0,0,15,0">
                    <Image x:Name="AlbumArtImage" Stretch="Uniform"/>
                </Border>

                <!-- 歌曲信息与控制 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Height="240">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 播放状态 -->
                        <TextBlock Grid.Column="0" x:Name="StatusTextBlock" FontSize="16" Foreground="Blue" 
                           Margin="0,0,0,10" Text="播放状态"/>
                        <CheckBox Grid.Column="1" x:Name="AutoStartCheckBox" Content="开机自启动" 
                          Margin="0,0,10,10" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                          Checked="AutoStartCheckBox_Checked" Unchecked="AutoStartCheckBox_Checked"/>
                    </Grid>
                    <!-- 标题 -->
                    <TextBlock x:Name="TitleTextBlock" FontSize="22" FontWeight="Bold" 
                       TextWrapping="Wrap" Margin="0,0,0,10" TextTrimming="CharacterEllipsis" MaxHeight="40"/>
                    <!-- 作者 -->
                    <TextBlock x:Name="ArtistTextBlock" FontSize="16" Foreground="#555" 
                       TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <!-- 专辑 -->
                    <TextBlock x:Name="AlbumTextBlock" FontSize="14" Foreground="#777" 
                       TextWrapping="Wrap"/>

                    <!-- 
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ControlStatusText" Text="未检测到可控制的媒体会话" 
                            FontSize="12" Foreground="#666"/>
                        <TextBlock x:Name="ControlResultText" FontSize="11" Margin="50,0,0,0"
                            TextWrapping="Wrap"/>
                    </StackPanel>
                     -->

                    <!-- 播放控制按钮 -->
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="SysPlayButton" Content="▶ 播放" Width="100" Height="35" 
                        Click="SysPlayButton_Click" Margin="0,0,10,0"
                        Background="#27AE60" Foreground="White" FontWeight="Bold"
                        IsEnabled="False"/>
                        <!-- 初始状态设为不可用 -->

                        <Button x:Name="SysPauseButton" Content="⏸ 暂停" Width="100" Height="35" 
                        Click="SysPauseButton_Click"
                        Background="#E74C3C" Foreground="White" FontWeight="Bold"
                        IsEnabled="False"/>
                        <!-- 初始状态设为不可用 -->
                    </StackPanel>


                    <!-- 传输状态信息 -->
                    <TextBlock x:Name="ImageTransferStatusText" Margin="0,10,0,0" FontSize="12" 
                   Foreground="Blue" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
